<mujoco model="standard_muscle_test">
  <option timestep="0.0001" gravity="0 0 -9.81"/>

  <default>
    <default class="muscle">
      <general biasprm="0.75 1.05 -1 400 0.5 1.6 1.5 1.3 1.2 0" biastype="muscle" ctrllimited="true" ctrlrange="0 1" dynprm="0.01 0.04 0 0 0 0 0 0 0 0" dyntype="muscle" gainprm="0.75 1.05 -1 400 0.5 1.6 1.5 1.3 1.2 0" gaintype="muscle"/>
    </default>
  </default>

  <worldbody>
    <body name="ground"/>
    
    <!-- Compliant tendon pendulum (left) -->
    <!-- <body name="pend_c" pos="-0.25 0 0.5">
      <joint name="hinge_c" type="hinge" axis="0 1 0" limited="true" range="-1.57 1.57"/>
      <geom type="capsule" fromto="0 0 0  0 0 -0.5" size="0.03" density="1000" rgba="0 0 1 1"/>
    </body> -->
    
    <!-- Rigid tendon (non-compliant) pendulum (right) -->
    <!-- <body name="pend_r" pos="0.25 0 0.5">
      <joint name="hinge_r" type="hinge" axis="0 1 0" limited="true" range="-1.57 1.57"/>
      <geom type="capsule" fromto="0 0 0  0 0 -0.5" size="0.03" density="1000" rgba="0 1 0 1"/>
    </body> -->

    <!-- Fixed anchor sites for tendons -->
    <site name="fixed_c" pos="-0.15 0 0.1" size="0.005" rgba="0 0 1 1"/>
    <site name="fixed_r" pos="0.15 0 0.1" size="0.005" rgba="0 1 0 1"/>

    <!-- Point masses to be pulled by muscles -->
    <body name="mass_c" pos="-0.15 0 0">
      <joint name="slide_c" type="slide" axis="0 0 1" limited="false" range="-1 0.0" damping="2"/>
      <site name="mass_c_site" pos="0 0 0" size="0.005" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.03" mass="1.0" rgba="0 0 1 1"/>
    </body>
    <body name="mass_r" pos="0.15 0 0">
      <joint name="slide_r" type="slide" axis="0 0 1" limited="false" range="-1 0.0" damping="2"/>
      <site name="mass_r_site" pos="0 0 0" size="0.005" rgba="0 1 0 1"/>
      <geom type="sphere" size="0.03" mass="1.0" rgba="0 1 0 1"/>
    </body>
  </worldbody>

  <!-- Tendon paths for muscles: fixed anchor to point mass site -->
  <tendon>
    <spatial name="tendon_c">
      <site site="fixed_c"/>
      <site site="mass_c_site"/>
    </spatial>
    <spatial name="tendon_r">
      <site site="fixed_r"/>
      <site site="mass_r_site"/>
    </spatial>
  </tendon>

  <actuator>
    <!-- Standard MuJoCo muscle pulling left point mass -->
    <muscle class="muscle" name="muscle_c" tendon="tendon_c" 
            lengthrange="0.05 0.5"/>

    <!-- Standard MuJoCo muscle pulling right point mass -->
    <muscle class="muscle" name="muscle_r" tendon="tendon_r" 
            lengthrange="0.05 0.5"/>
  </actuator>

  <sensor>
    <tendonpos name="len_c" tendon="tendon_c"/>
    <tendonpos name="len_r" tendon="tendon_r"/>
    <actuatorfrc name="frc_c" actuator="muscle_c"/>
    <actuatorfrc name="frc_r" actuator="muscle_r"/>
  </sensor>
</mujoco>
